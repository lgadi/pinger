{
  "permissions": {
    "allow": [
      "Bash(swift build:*)",
      "Bash(swift --version)",
      "Bash(swift package:*)",
      "Bash(xcode-select -p)",
      "Bash(xcrun swift:*)",
      "Read(//Library/Developer/CommandLineTools/usr/lib/swift/pm/ManifestAPI/**)",
